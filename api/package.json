{
  "name": "fl-web-explorer-api",
  "scripts": {
    "dev": "node --env-file .env --watch --enable-source-maps ./dist/index.js",
    "build:dev": "concurrently --kill-others \"nodemon --watch \"src/**\" -e ts --ignore \"src/**/*.spec.ts\" --exec npm run build\" \"npm run dev\"",
    "build": "tsc"
  },
  "dependencies": {
    "@imagemagick/magick-wasm": "^0.0.34",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "imagemagick": "^0.1.3",
    "jsdom": "^26.0.0",
    "lodash": "^4.17.21",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/imagemagick": "^0.0.35",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.13.13",
    "@types/xmldom": "^0.1.34",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2"
  }
}
